# SentinelCRE Dashboard — Environment Template
# Copy this file to .env.local and fill in the placeholder values.
#   cp .env.example .env.local

NEXT_PUBLIC_MOCK_API_URL=http://localhost:3002
NEXT_PUBLIC_GUARDIAN_ADDRESS=0x5F938e4c62991Eb4af3Dd89097978A1f376e6CC8
NEXT_PUBLIC_REGISTRY_ADDRESS=0xFA7deF53FEaC45dB96A5B15C32ca4E6B009b25e6
NEXT_PUBLIC_RPC_URL=https://your-tenderly-virtual-testnet-rpc-url

# Deployer wallet (server-side only — submits verdicts on-chain)
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Tenderly Pro API (server-side only — no NEXT_PUBLIC_ prefix)
TENDERLY_ACCESS_KEY=your-tenderly-access-key
TENDERLY_ACCOUNT_SLUG=your-tenderly-account-slug
TENDERLY_PROJECT_SLUG=your-tenderly-project-slug
